rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can read portfolio data, nobody can write from the client
    match /portfolio/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Users can submit quiz answers - write only, no reading others' answers
    match /quizAnswers/{document=**} {
      allow read: if false;
      allow write: if true;
    }

    // Users can submit comments - write only, no reading others' comments
    match /comments/{document=**} {
      allow read: if false;
      allow write: if true;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }

  }
}